{
  "manifest_version": 3,
  "name": "Zoom Audio → Traductor",
  "version": "1.0",
  "description": "Captura el audio de la pestaña activa y lo envía al servidor de traducción.",
  "permissions": ["tabCapture", "activeTab", "storage", "offscreen"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Zoom Tradutor"
  },
  "background": {
    "service_worker": "background.js"
  }
}
